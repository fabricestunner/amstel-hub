{
  "name": "amstel-rewards-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise Loyalty, Rewards & Tournament Management Platform for a nationwide brewery campaign.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @amstel/api db:generate",
    "db:migrate": "pnpm --filter @amstel/api db:migrate",
    "db:seed": "pnpm --filter @amstel/api db:seed",
    "db:studio": "pnpm --filter @amstel/api db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
